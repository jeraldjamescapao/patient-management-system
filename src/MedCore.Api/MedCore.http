@MedCore_HostAddress = https://localhost:7212
@ContentType = application/json

# Copy an access token from a login or register response and paste it here.
@AccessToken = 

###

# ─────────────────────────────────────────
# Welcome to MedCore!
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/
Accept: text/plain

###

# ─────────────────────────────────────────
# Auth — Login as Seeded Admin
# Use this to get an Admin Bearer token for testing admin endpoints.
# Credentials match the AdminSeed section in appsettings.json.
# Returns: 200 with access token.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/auth/login
Content-Type: {{ContentType}}

{
  "email": "admin@medcore.dev",
  "password": "Admin_MedCore_2026!"
}

###

# ─────────────────────────────────────────
# Auth — Register
# Creates a new Patient account and sends a confirmation email.
# Returns: 201 with access token + sets HttpOnly refresh token cookie.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/auth/register
Content-Type: {{ContentType}}

{
  "firstName": "Jerald James Capao",
  "lastName": "Test",
  "email": "dayton43@ethereal.email",
  "password": "ThePasswordOfAllSeasons1!",
  "birthDate": "1988-06-27",
  "culture": "fr"
}

###

# ─────────────────────────────────────────
# Auth — Login
# Returns: 200 with access token + sets HttpOnly refresh token cookie.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/auth/login
Content-Type: {{ContentType}}

{
  "email": "dayton43@ethereal.email",
  "password": "ThePasswordOfAllSeasons1!"
}

###

# ─────────────────────────────────────────
# Auth — Refresh
# Uses the HttpOnly refresh token cookie automatically (browser/IDE handles it).
# Returns: 200 with a new access token + rotates the refresh token cookie.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/auth/refresh

###

# ─────────────────────────────────────────
# Auth — Logout
# Revokes the current refresh token. Cookie is cleared.
# Returns: 204 No Content.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/auth/logout

###

# ─────────────────────────────────────────
# Auth — Logout All
# Revokes all active sessions for the authenticated user.
# Requires: Bearer token in Authorization header.
# Returns: 204 No Content.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/auth/logout-all
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# Auth — Confirm Email
# Paste the userId and token from the confirmation email link here.
# Returns: 204 No Content on success.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/auth/confirm-email?userId=00000000-0000-0000-0000-000000000000&token=PASTE_TOKEN_HERE

###

# ─────────────────────────────────────────
# Auth — Resend Confirmation Email
# Silently succeeds even if the email is unknown or already confirmed (anti-enumeration).
# Returns: 204 No Content.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/auth/resend-confirmation-email
Content-Type: {{ContentType}}

{
  "email": "dayton43@ethereal.email"
}

###

# ─────────────────────────────────────────
# Users — Get Current User
# Returns the authenticated user's profile.
# Requires: valid Bearer token.
# Returns: 200 with user profile.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/users/me
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# Users — Update Preferred Culture
# Updates the authenticated user's preferred language.
# Supported values: en, fr, de, fr-CH, de-CH
# Requires: valid Bearer token.
# Returns: 204 No Content.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/users/me/culture
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "culture": "de"
}

###

# ─────────────────────────────────────────
# Users — Update Profile
# Updates the authenticated user's name and birth date.
# Note: name and birth date changes are audit-logged.
# Requires: valid Bearer token.
# Returns: 200 with updated user profile.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/users/me/profile
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "firstName": "Jerald James Capao",
  "lastName": "Test Update",
  "birthDate": "1965-10-10"
}

###

# ─────────────────────────────────────────
# Users — Update Phone Number
# Updates the authenticated user's phone number.
# Phone number confirmation (SMS) is not yet implemented.
# Requires: valid Bearer token.
# Returns: 204 No Content.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/users/me/phone
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "phoneNumber": "+41 79 123 45 67"
}

###

# ─────────────────────────────────────────
# Localization — Refresh Translation Cache
# Clears and reloads the in-memory translation cache from the database.
# Use this after updating a translation row directly in the DB.
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/translations/cache/refresh
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# Localization — Get All Translations
# Returns all translations, optionally filtered by culture.
# Supported culture values: en, fr, de, fr-CH, de-CH
# Requires: valid Bearer token with Admin role.
# Returns: 200 with list of translations.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/translations
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# Localization — Get All Translations by Culture
# Requires: valid Bearer token with Admin role.
# Returns: 200 with filtered list of translations.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/translations?culture=fr
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# Localization — Get Translation by ID
# Requires: valid Bearer token with Admin role.
# Returns: 200 with translation, or 404 if not found.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/translations/1
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# Localization — Create Translation
# Requires: valid Bearer token with Admin role.
# Returns: 201 with created translation.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/translations
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "culture": "en",
  "key": "app.general.get_well_soon",
  "value": "Get well soon!",
  "description": "Get well soon wish."
}

###

# ─────────────────────────────────────────
# Localization — Update Translation
# Culture and Key are not updatable.
# Requires: valid Bearer token with Admin role.
# Returns: 200 with updated translation.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/translations/1
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "value": "MedCore by Jerald James Capao © 2026",
  "description": "Updated general app name."
}

###

# ─────────────────────────────────────────
# Localization — Delete Translation (Soft)
# Sets IsActive to false. Preserves audit trail.
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

DELETE {{MedCore_HostAddress}}/api/v1/translations/1
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Get All Categories (Admin)
# Returns all categories excluding deleted ones.
# Requires: valid Bearer token with Admin role.
# Returns: 200 with list of categories.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/code-items/categories
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Get Category by ID (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 200 with category, or 404 if not found.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/code-items/categories/1
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Create Category (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 201 with created category.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/code-items/categories
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "code": "custom.category",
  "description": "A custom admin-created category",
  "sortOrder": 300
}

###

# ─────────────────────────────────────────
# CodeItems — Update Category (Admin)
# Code is not updatable.
# Requires: valid Bearer token with Admin role.
# Returns: 200 with updated category.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/1
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "description": "Updated description",
  "sortOrder": 10
}

###

# ─────────────────────────────────────────
# CodeItems — Activate Category (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/1/activate
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Deactivate Category (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/1/deactivate
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Delete Category (Admin)
# Soft delete. Blocked if active items exist.
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

DELETE {{MedCore_HostAddress}}/api/v1/code-items/categories/1
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Reorder Categories (Admin)
# Accepts a list of { id, sortOrder } pairs.
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/reorder
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "entries": [
    { "id": 1, "sortOrder": 10 },
    { "id": 2, "sortOrder": 20 }
  ]
}

###

# ─────────────────────────────────────────
# CodeItems — Get Items by Category (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 200 with list of items.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Get Item by ID (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 200 with item, or 404 if not found.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items/1
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Create Item (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 201 with created item.
# ─────────────────────────────────────────

POST {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "code": "CustomItem",
  "description": "A custom admin-created item",
  "sortOrder": 999
}

###

# ─────────────────────────────────────────
# CodeItems — Update Item (Admin)
# Code is not updatable.
# Requires: valid Bearer token with Admin role.
# Returns: 200 with updated item.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items/1
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "description": "Updated item description",
  "sortOrder": 10
}

###

# ─────────────────────────────────────────
# CodeItems — Activate Item (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items/1/activate
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Deactivate Item (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items/1/deactivate
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Delete Item (Admin)
# Soft delete. Cascades to item translations.
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

DELETE {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items/1
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Reorder Items (Admin)
# Accepts a list of { id, sortOrder } pairs.
# Requires: valid Bearer token with Admin role.
# Returns: 204 No Content.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items/reorder
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "entries": [
    { "id": 1, "sortOrder": 10 },
    { "id": 2, "sortOrder": 20 }
  ]
}

###

# ─────────────────────────────────────────
# CodeItems — Get Category Translations (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 200 with list of translations.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/code-items/categories/1/translations
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Upsert Category Translation (Admin)
# Creates or updates the label for a category in a specific culture.
# Supported culture values: en, fr, de, fr-CH, de-CH
# Requires: valid Bearer token with Admin role.
# Returns: 200 with translation.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/1/translations/en
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "label": "Appointment Type",
  "description": null
}

###

# ─────────────────────────────────────────
# CodeItems — Get Item Translations (Admin)
# Requires: valid Bearer token with Admin role.
# Returns: 200 with list of translations.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items/1/translations
Authorization: Bearer {{AccessToken}}

###

# ─────────────────────────────────────────
# CodeItems — Upsert Item Translation (Admin)
# Creates or updates the label for an item in a specific culture.
# Supported culture values: en, fr, de, fr-CH, de-CH
# Requires: valid Bearer token with Admin role.
# Returns: 200 with translation.
# ─────────────────────────────────────────

PUT {{MedCore_HostAddress}}/api/v1/code-items/categories/1/items/1/translations/fr
Content-Type: {{ContentType}}
Authorization: Bearer {{AccessToken}}

{
  "label": "Consultation",
  "description": null
}

###

# ─────────────────────────────────────────
# CodeItems — Get Active Items (Consumer)
# Returns active items for the given category code in the
# current user's culture. Falls back to English if no label exists.
# Requires: valid Bearer token (any role).
# Returns: 200 with category code and list of { code, label }.
# ─────────────────────────────────────────

GET {{MedCore_HostAddress}}/api/v1/code-items/appointment.type
Authorization: Bearer {{AccessToken}}

###